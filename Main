function loadStoreInfo() {
    db.ref('store').once('value').then(snap => {
        if (snap.val()) {
            const s = snap.val();
            storeInfo = { name: s.name || storeInfo.name, logo: s.logo || '', slogan: s.slogan || storeInfo.slogan, aboutAdmin: s.aboutAdmin || '' };
            if (s.helpSupport) helpSupport = s.helpSupport;
        }
        applyStoreInfo();
    }).catch(() => {});
}

function applyStoreInfo() {
    const logoSrc = storeInfo.logo || 'https://picsum.photos/seed/storelogo/144/144.jpg';
    document.getElementById('authLogo').src = logoSrc;
    document.getElementById('authStoreName').textContent = storeInfo.name;
    document.getElementById('authStoreSlogan').textContent = storeInfo.slogan;
    document.getElementById('appLogo').src = logoSrc;
    document.getElementById('appStoreName').textContent = storeInfo.name;
    document.getElementById('appStoreSlogan').textContent = storeInfo.slogan;
    document.getElementById('aboutAdminText').textContent = storeInfo.aboutAdmin || 'No information available yet.';
    renderSupportLinks();
}

function renderSupportLinks() {
    const c = document.getElementById('supportLinks');
    let html = '';
    if (helpSupport.email) html += `<a class="support-link" href="mailto:${escapeHtml(helpSupport.email)}" style="background:#EA4335" title="Email"><i class="fas fa-envelope"></i></a>`;
    if (helpSupport.whatsapp) html += `<a class="support-link" href="${escapeHtml(helpSupport.whatsapp)}" target="_blank" style="background:#25D366" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>`;
    if (helpSupport.facebook) html += `<a class="support-link" href="${escapeHtml(helpSupport.facebook)}" target="_blank" style="background:#1877F2" title="Facebook"><i class="fab fa-facebook-f"></i></a>`;
    if (helpSupport.telegram) html += `<a class="support-link" href="${escapeHtml(helpSupport.telegram)}" target="_blank" style="background:#0088CC" title="Telegram"><i class="fab fa-telegram-plane"></i></a>`;
    c.innerHTML = html || '<span style="font-size:13px;color:var(--text-sec)">No support links available</span>';
}

