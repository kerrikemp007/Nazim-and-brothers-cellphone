function showAuthTab(tab) {
    document.getElementById('loginForm').style.display = tab === 'login' ? 'block' : 'none';
    document.getElementById('registerForm').style.display = tab === 'register' ? 'block' : 'none';
    document.getElementById('tabLogin').classList.toggle('active', tab === 'login');
    document.getElementById('tabRegister').classList.toggle('active', tab === 'register');
    document.getElementById('authMsg').style.display = 'none';
}

function showAuthMsg(msg, type) {
    const el = document.getElementById('authMsg');
    el.textContent = msg;
    el.className = 'auth-msg ' + type;
    el.style.display = 'block';
}

async function handleRegister(e) {
    e.preventDefault();
    const name = document.getElementById('regName').value.trim();
    const email = document.getElementById('regEmail').value.trim();
    const pass = document.getElementById('regPass').value;

    if (!/^\d{6}$/.test(pass)) {
        showAuthMsg('Passcode must be exactly 6 digits.', 'err');
        return;
    }

    const btn = document.getElementById('regBtn');
    btn.disabled = true;
    btn.textContent = 'Creating account...';

    try {
        const cred = await auth.createUserWithEmailAndPassword(email, pass);
        await db.ref('users/' + cred.user.uid).set({
            name: name, email: email, profilePic: '', status: 'pending', verified: false, firstLogin: true,
            joinedDate: firebase.database.ServerValue.TIMESTAMP
        });
        await auth.signOut();
        showAuthMsg('Account created successfully! Please wait for admin approval.', 'ok');
        document.getElementById('registerForm').reset();
    } catch (err) {
        let msg = 'Registration failed.';
        if (err.code === 'auth/email-already-in-use') msg = 'Email already registered.';
        showAuthMsg(msg, 'err');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Register';
    }
}

async function handleLogin(e) {
    e.preventDefault();
    const email = document.getElementById('loginEmail').value.trim();
    const pass = document.getElementById('loginPass').value;
    const btn = document.getElementById('loginBtn');
    btn.disabled = true;
    btn.textContent = 'Logging in...';
    try { await auth.signInWithEmailAndPassword(email, pass); } 
    catch (err) { showAuthMsg('Login failed. Check your credentials.', 'err'); btn.disabled = false; btn.textContent = 'Login'; }
}

function handleLogout() {
    auth.signOut().then(() => { showToast('Logged out successfully', 'info'); }).catch(() => {});
}

auth.onAuthStateChanged(async (user) => {
    const overlay = document.getElementById('loadingOverlay');
    if (user) {
        try {
            const snap = await db.ref('users/' + user.uid).once('value');
            const data = snap.val();
            if (!data || data.status === 'pending' || data.status === 'banned') {
                await auth.signOut();
                showScreen('auth');
                if (data?.status === 'pending') showAuthMsg('Your account is pending approval.', 'warn');
                overlay.classList.add('hide');
                return;
            }
            currentUser = user; userData = data;
            showScreen('app'); renderCategories(); loadProfile(); loadNotifications(); listenVerification();
            history.replaceState({view: 'home'}, "");
            if (data.firstLogin) {
                await db.ref('userNotifications/' + user.uid).push({
                    title: 'Welcome!', text: 'Welcome to our store! Browse categories to find your parts.',
                    timestamp: firebase.database.ServerValue.TIMESTAMP, read: false
                });
                await db.ref('users/' + user.uid + '/firstLogin').set(false);
            }
        } catch (err) { await auth.signOut(); showScreen('auth'); }
    } else { currentUser = null; userData = null; showScreen('auth'); }
    overlay.classList.add('hide');
});

function showScreen(which) {
    document.getElementById('authScreen').style.display = which === 'auth' ? 'flex' : 'none';
    document.getElementById('mainApp').style.display = which === 'app' ? 'block' : 'none';
}

/* ── NAVIGATION ── */
function switchTab(tab) {
    if (history.state?.view !== tab) history.pushState({view: tab}, "");
    internalSwitchTab(tab);
}

function internalSwitchTab(tab) {
    document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    if (tab === 'home') {
        document.getElementById('viewHome').classList.add('active');
        document.getElementById('navHome').classList.add('active');
    } else if (tab === 'update') {
        document.getElementById('viewUpdate').classList.add('active');
        document.getElementById('navUpdate').classList.add('active');
        loadNotifications();
    } else if (tab === 'profile') {
        document.getElementById('viewProfile').classList.add('active');
        document.getElementById('navProfile').classList.add('active');
        loadProfile();
    }
}

function openCategory(catName) {
    history.pushState({view: 'products', category: catName}, "");
    internalOpenCategory(catName);
}

function internalOpenCategory(catName) {
    currentCategory = catName; activeBrandFilter = 'all';
    document.getElementById('productsTitle').textContent = catName;
    document.getElementById('productSearch').value = '';
    document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
    document.getElementById('viewProducts').classList.add('active');
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    loadProducts(catName);
}

function goHome() { if (history.state?.view !== 'home') history.back(); }

/* ═══════════════════════════════════════
   PRODUCTS & SEARCH LOGIC
   ═══════════════════════════════════════ */

// 1. Helper function to highlight matches with color
function highlightMatch(text, query) {
    if (!query) return escapeHtml(text);
    // Use word boundary \b to highlight only the exact word match
    const regex = new RegExp(`(\\b${query}\\b)`, 'gi');
    let safeText = escapeHtml(text);
    return safeText.replace(regex, '<span class="highlight">$1</span>');
}

// 2. Updated Filter logic using Word Boundaries (\b)
function filterProducts() {
    const query = document.getElementById('productSearch').value.trim().toLowerCase();
    let filtered = [...cachedProducts];

    if (activeBrandFilter !== 'all') {
        filtered = filtered.filter(p => (p.brand || '').toUpperCase() === activeBrandFilter.toUpperCase());
    }

    if (query) {
        // Create Regex with \b (Word Boundaries) 
        // This stops "Y20" from matching "Y200E"
        const regex = new RegExp('\\b' + query + '\\b', 'i');

        filtered = filtered.filter(p => {
            const mainModel = (p.mainModelName || '').toLowerCase();
            const compatible = (p.compatibleModels || '').toLowerCase();
            const brand = (p.brand || '').toLowerCase();
            return regex.test(mainModel) || regex.test(compatible) || regex.test(brand);
        });
    }

    renderProductList(filtered, query);
}

function loadProducts(category) {
    const list = document.getElementById('productsList');
    list.innerHTML = '<div class="spinner-wrap"><div class="spinner"></div></div>';
    document.getElementById('brandFilters').innerHTML = '';
    db.ref('products').orderByChild('category').equalTo(category).once('value').then(snap => {
        const data = snap.val();
        cachedProducts = data ? Object.entries(data).map(([id, p]) => ({ id, ...p })) : [];
        buildBrandFilters();
        renderProductList(cachedProducts);
    }).catch(() => {
        list.innerHTML = '<div class="empty-state"><p>Failed to load products</p></div>';
    });
}

function buildBrandFilters() {
    const brands = [...new Set(cachedProducts.map(p => (p.brand || '').toUpperCase()).filter(Boolean))];
    const container = document.getElementById('brandFilters');
    let html = '<button class="brand-tag active" onclick="setBrandFilter(\'all\')">All</button>';
    brands.forEach(b => { html += `<button class="brand-tag" onclick="setBrandFilter('${escapeHtml(b)}')">${escapeHtml(b)}</button>`; });
    container.innerHTML = html;
}

function setBrandFilter(brand) {
    activeBrandFilter = brand;
    document.querySelectorAll('.brand-tag').forEach(t => {
        t.classList.toggle('active', t.textContent.trim().toUpperCase() === brand.toUpperCase() || (brand === 'all' && t.textContent.trim() === 'All'));
    });
    filterProducts();
}

// 3. Updated Renderer logic to apply colors
function renderProductList(products, query = '') {
    const list = document.getElementById('productsList');
    if (!products.length) {
        list.innerHTML = '<div class="empty-state"><i class="fas fa-box-open"></i><p>No products found</p></div>';
        return;
    }
    list.innerHTML = products.map(p => {
        const models = (p.compatibleModels || '').split(',').map(m => m.trim()).filter(Boolean);
        const totalCompat = models.length;
        
        // Highlight logic applied here
        const hBrand = highlightMatch(p.brand || 'N/A', query);
        const hModel = highlightMatch(p.mainModelName || 'Untitled', query);
        
        const displayModels = models.slice(0, 3).join(', ');
        const hCompat = highlightMatch(displayModels, query);
        
        const hasMore = models.length > 3;
        return `
        <div class="product-card" id="pcard-${p.id}">
            <div class="brand-label">${hBrand}</div>
            <div class="model-name">${hModel}</div>
            <div class="compat" id="compat-${p.id}">${hCompat}${hasMore ? ', ...' : ''}</div>
            ${hasMore ? `<span class="compat-more" onclick="event.stopPropagation();toggleCompat('${p.id}',${totalCompat})">+${totalCompat - 3} more models</span>` : ''}
            <div class="meta-row">
                <div class="meta-left">
                    <span><i class="fas fa-layer-group"></i>${totalCompat} compatible</span>
                    &nbsp;&middot;&nbsp;
                    <span><i class="fas fa-eye"></i>${p.views || 0}</span>
                </div>
                <button class="share-btn" onclick="event.stopPropagation();shareProduct('${p.id}')">
                    <i class="fas fa-copy"></i>Copy
                </button>
            </div>
        </div>`;
    }).join('');

    list.querySelectorAll('.product-card').forEach(card => {
        card.addEventListener('click', function() {
            const id = this.id.replace('pcard-', '');
            db.ref('products/' + id + '/views').transaction(count => (count || 0) + 1);
        });
    });
}

function toggleCompat(productId, total) {
    const el = document.getElementById('compat-' + productId);
    const card = document.getElementById('pcard-' + productId);
    if (!el || !card) return;
    const isExpanded = card.classList.contains('expanded');
    const p = cachedProducts.find(x => x.id === productId);
    const models = (p.compatibleModels || '').split(',').map(m => m.trim()).filter(Boolean);
    const query = document.getElementById('productSearch').value.trim();

    if (isExpanded) {
        const displayModels = models.slice(0, 3).join(', ');
        el.innerHTML = highlightMatch(displayModels, query) + (models.length > 3 ? ', ...' : '');
        card.classList.remove('expanded');
        card.querySelector('.compat-more').textContent = '+' + (total - 3) + ' more models';
    } else {
        el.innerHTML = highlightMatch(p.compatibleModels || '', query);
        card.classList.add('expanded');
        card.querySelector('.compat-more').textContent = 'Show less';
    }
}

function shareProduct(productId) {
    const p = cachedProducts.find(x => x.id === productId);
    if (!p) return;
    const text = `*${p.brand} ${p.mainModelName}*\nCompatible: ${p.compatibleModels}`;
    if (navigator.share) { navigator.share({ title: p.mainModelName, text: text }).catch(() => {}); } 
    else { navigator.clipboard.writeText(text).then(() => showToast('Copied to clipboard', 'success')); }
}

/* ── UI RENDERERS ── */
function renderCategories() {
    const grid = document.getElementById('catGrid');
    grid.innerHTML = categories.map(c => `
        <div class="cat-card" onclick="openCategory('${escapeHtml(c.name)}')">
            <div class="cat-icon" style="background:${c.color}">
                <i class="fas ${c.icon}"></i>
            </div>
            <span>${escapeHtml(c.name)}</span>
        </div>
    `).join('');
}

function loadNotifications() {
    if (!currentUser) return;
    const list = document.getElementById('notifList');
    list.innerHTML = '<div class="spinner-wrap"><div class="spinner"></div></div>';
    db.ref('broadcasts').once('value').then(bSnap => {
        cachedBroadcasts = bSnap.val() || {};
        return db.ref('userNotifications/' + currentUser.uid).once('value');
    }).then(uSnap => {
        cachedUserNotifs = uSnap.val() || {};
        renderNotifications();
    });
}

function renderNotifications() {
    const list = document.getElementById('notifList');
    const items = [];
    Object.entries(cachedUserNotifs).forEach(([id, n]) => items.push({ id, ...n, source: 'user' }));
    Object.entries(cachedBroadcasts).forEach(([id, n]) => items.push({ id, ...n, source: 'broadcast', read: false }));
    db.ref('userReadBroadcasts/' + currentUser.uid).once('value').then(snap => {
        const readMap = snap.val() || {};
        items.forEach(item => { if (item.source === 'broadcast' && readMap[item.id]) item.read = true; });
        items.sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0));
        const unreadCount = items.filter(i => !i.read).length;
        const badge = document.getElementById('notifBadge');
        badge.textContent = unreadCount;
        badge.style.display = unreadCount > 0 ? 'flex' : 'none';
        if (!items.length) { list.innerHTML = '<div class="empty-state"><p>No notifications yet</p></div>'; return; }
        list.innerHTML = items.map(n => `
            <div class="notif-item ${n.read ? '' : 'unread'}" onclick="openNotif('${n.id}','${n.source}')">
                <div class="notif-title">${escapeHtml(n.title || '')}</div>
                <div class="notif-preview">${escapeHtml(n.text || '')}</div>
                <div class="notif-time">${timeAgo(n.timestamp)}</div>
            </div>
        `).join('');
    });
}

function openNotif(id, source) {
    const n = source === 'broadcast' ? cachedBroadcasts[id] : cachedUserNotifs[id];
    if (!n) return;
    if (source === 'broadcast') db.ref('userReadBroadcasts/' + currentUser.uid + '/' + id).set(true);
    else db.ref('userNotifications/' + currentUser.uid + '/' + id + '/read').set(true);
    document.getElementById('modalTitle').textContent = n.title;
    document.getElementById('modalTime').textContent = formatDate(n.timestamp);
    document.getElementById('modalText').textContent = n.text;
    document.getElementById('notifModal').classList.add('show');
    renderNotifications();
}

function closeNotifModal() { document.getElementById('notifModal').classList.remove('show'); }

function readAllNotifs() {
    const updates = {};
    Object.keys(cachedUserNotifs).forEach(id => updates['userNotifications/' + currentUser.uid + '/' + id + '/read'] = true);
    Object.keys(cachedBroadcasts).forEach(id => updates['userReadBroadcasts/' + currentUser.uid + '/' + id] = true);
    db.ref().update(updates).then(() => { showToast('All marked as read'); renderNotifications(); });
}

function loadProfile() {
    if (!userData) return;
    document.getElementById('profileAvatar').src = userData.profilePic || 'https://i.pravatar.cc/300';
    document.getElementById('profileName').textContent = userData.name;
    document.getElementById('profileEmail').textContent = userData.email;
    document.getElementById('profileJoined').textContent = 'Joined: ' + formatDate(userData.joinedDate);
    document.getElementById('profileBadge').innerHTML = userData.verified ? 
        '<span class="badge verified"><i class="fas fa-check-circle"></i> Verified</span>' : 
        '<span class="badge unverified"><i class="fas fa-clock"></i> Unverified</span>';
}

function listenVerification() {
    db.ref('users/' + currentUser.uid + '/verified').on('value', snap => {
        if (userData) userData.verified = snap.val();
        if (document.getElementById('viewProfile').classList.contains('active')) loadProfile();
    });
}

async function submitRequest(e) {
    e.preventDefault();
    const sub = document.getElementById('reqSubject').value.trim();
    const msg = document.getElementById('reqMessage').value.trim();
    await db.ref('userMessages').push({
        userId: currentUser.uid, userName: userData.name, userEmail: userData.email, subject: sub, message: msg,
        timestamp: firebase.database.ServerValue.TIMESTAMP, read: false
    });
    document.getElementById('reqSubject').value = '';
    document.getElementById('reqMessage').value = '';
    showToast('Request sent successfully!', 'success');
}

loadStoreInfo();
